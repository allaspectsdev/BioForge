# Database
BIOFORGE_DATABASE_URL=postgresql+asyncpg://bioforge:bioforge@localhost:5432/bioforge

# Object Storage (MinIO)
BIOFORGE_S3_ENDPOINT=http://localhost:9000
BIOFORGE_S3_ACCESS_KEY=minioadmin
BIOFORGE_S3_SECRET_KEY=minioadmin
BIOFORGE_S3_BUCKET=bioforge-data

# AI
BIOFORGE_ANTHROPIC_API_KEY=
BIOFORGE_DEFAULT_MODEL=claude-sonnet-4-20250514
BIOFORGE_AGENT_MAX_TURNS=25
BIOFORGE_AGENT_MAX_BUDGET_USD=1.0

# Platform
BIOFORGE_DEBUG=true
BIOFORGE_LOG_LEVEL=INFO
